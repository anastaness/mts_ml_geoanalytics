<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ project_title }}</title>
  <style>
    :root {
      --red: {{ palette.red }};
      --purple: {{ palette.purple }};
      --purple-2: {{ palette.purple_2 }};
      --white: {{ palette.white }};
      --black: {{ palette.black }};
      --bg: {{ palette.bg }};
      --line: rgba(23, 23, 28, 0.08);
      --muted: rgba(23, 23, 28, 0.65);
      --shadow: 0 14px 34px rgba(99, 81, 183, 0.10);
      --radius-xl: 26px;
      --radius-lg: 20px;
      --radius-md: 15px;
    }

    @page {
      size: A3 landscape;
      margin: 0;
    }

    * { box-sizing: border-box; }

    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      font-family: Inter, Arial, Helvetica, sans-serif;
      color: var(--black);
      background: var(--bg);
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    body {
      background:
        radial-gradient(circle at 100% 0%, rgba(99, 81, 183, 0.07), transparent 22%),
        radial-gradient(circle at 0% 100%, rgba(254, 0, 50, 0.05), transparent 18%),
        linear-gradient(180deg, #f8f6fd 0%, var(--bg) 100%);
    }

    .page {
      width: 420mm;
      height: 297mm;
      padding: 11mm 12mm 9mm 12mm;
      overflow: hidden;
      background:
        radial-gradient(circle at 100% 0%, rgba(99, 81, 183, 0.08), transparent 20%),
        radial-gradient(circle at 0% 100%, rgba(254, 0, 50, 0.05), transparent 16%),
        linear-gradient(180deg, #f8f6fd 0%, var(--bg) 100%);
      position: relative;
    }

    .top-line {
      position: absolute;
      left: 0;
      top: 0;
      right: 0;
      height: 6mm;
      background: linear-gradient(90deg, var(--red) 0%, var(--purple) 58%, var(--purple-2) 100%);
    }

    .layout {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-rows: auto auto auto 1fr;
      gap: 3.8mm;
      height: 100%;
      margin-top: 4mm;
    }

    .header {
      display: grid;
      grid-template-columns: 1.45fr 0.75fr;
      gap: 7mm;
      align-items: start;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      padding: 6px 13px;
      border-radius: 999px;
      background: rgba(99, 81, 183, 0.08);
      border: 1px solid rgba(99, 81, 183, 0.18);
      color: var(--purple);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    h1 {
      margin: 4mm 0 2mm 0;
      font-size: 24px;
      line-height: 1.05;
      letter-spacing: -0.03em;
    }

    .subtitle {
      margin: 0;
      font-size: 11.2px;
      line-height: 1.45;
      color: var(--muted);
      max-width: 240mm;
    }

    .logo-wrap {
      display: flex;
      justify-content: flex-end;
    }

    .logo-box {
      width: 52mm;
      height: 23mm;
      background: var(--white);
      border: 1px solid var(--line);
      border-radius: 18px;
      box-shadow: var(--shadow);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 4mm;
    }

    .logo-box img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      object-position: right center;
      display: block;
    }

    .overview {
      display: grid;
      grid-template-columns: repeat(4, 1fr) 1.3fr;
      gap: 3.5mm;
    }

    .card {
      background: rgba(255,255,255,0.94);
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow);
      padding: 3.7mm;
      min-height: 0;
    }

    .overview-card.dark {
      background: linear-gradient(135deg, var(--black) 0%, #2a2a35 100%);
      color: var(--white);
    }

    .overview-card.red {
      background: linear-gradient(180deg, rgba(254, 0, 50, 0.08), rgba(255,255,255,0.98));
      border-color: rgba(254, 0, 50, 0.18);
    }

    .overview-card .label {
      font-size: 10.5px;
      line-height: 1.3;
      font-weight: 700;
      color: var(--muted);
      margin-bottom: 2mm;
    }

    .overview-card.dark .label,
    .overview-card.dark .note {
      color: rgba(255,255,255,0.75);
    }

    .overview-card .value {
      font-size: 18px;
      line-height: 1;
      font-weight: 900;
      letter-spacing: -0.03em;
      margin-bottom: 2mm;
    }

    .overview-card .note {
      font-size: 9.5px;
      line-height: 1.35;
      color: rgba(23, 23, 28, 0.52);
    }

    .hero {
      background: linear-gradient(135deg, rgba(99,81,183,0.96) 0%, rgba(125,109,216,0.96) 100%);
      color: var(--white);
      border-radius: var(--radius-xl);
      padding: 4.2mm 5mm;
      box-shadow: 0 16px 42px rgba(99,81,183,0.22);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .hero .k {
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      opacity: 0.92;
      margin-bottom: 2mm;
    }

    .hero .v {
      font-size: 32px;
      line-height: 1;
      font-weight: 900;
      letter-spacing: -0.04em;
      margin-bottom: 1.8mm;
    }

    .hero .t {
      font-size: 10.6px;
      line-height: 1.42;
      opacity: 0.96;
    }

    .middle {
      display: grid;
      grid-template-columns: 1.08fr 1.02fr 0.9fr;
      gap: 3.6mm;
      min-height: 0;
    }

    .bottom {
      display: grid;
      grid-template-columns: 1.08fr 1.02fr 0.9fr;
      gap: 3.6mm;
      min-height: 0;
    }

    .panel {
      display: flex;
      flex-direction: column;
      min-height: 0;
    }

    .panel-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 3mm;
      margin-bottom: 2.8mm;
    }

    .panel-title {
      margin: 0;
      font-size: 15.5px;
      letter-spacing: -0.02em;
    }

    .pill {
      padding: 2.2mm 3mm;
      border-radius: 999px;
      background: rgba(99, 81, 183, 0.08);
      color: var(--purple);
      border: 1px solid rgba(99, 81, 183, 0.14);
      font-size: 9.5px;
      font-weight: 800;
      white-space: nowrap;
    }

    .score {
      border-radius: var(--radius-lg);
      background: linear-gradient(180deg, rgba(254, 0, 50, 0.05), rgba(99, 81, 183, 0.07));
      border: 1px solid var(--line);
      padding: 3.2mm;
      margin-bottom: 2.6mm;
    }

    .score-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 4mm;
      margin-bottom: 1.8mm;
    }

    .score .left .k {
      font-size: 9.7px;
      color: var(--muted);
      font-weight: 700;
      margin-bottom: 0.8mm;
    }

    .score .left .v {
      font-size: 26px;
      line-height: 1;
      font-weight: 900;
      color: var(--purple);
    }

    .score .right {
      text-align: right;
      font-size: 10px;
      color: var(--red);
      font-weight: 800;
    }

    .track {
      height: 8px;
      border-radius: 999px;
      background: rgba(99,81,183,0.12);
      overflow: hidden;
    }

    .fill {
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--red) 0%, var(--purple) 55%, var(--purple-2) 100%);
    }

    .mini-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5mm;
    }

    .mini-grid.cols-1 { grid-template-columns: 1fr; }
    .mini-grid.cols-3 { grid-template-columns: repeat(3, 1fr); }

    .mini {
      border-radius: var(--radius-md);
      border: 1px solid var(--line);
      background: var(--white);
      padding: 2.8mm 3mm;
      min-height: 22mm;
    }

    .mini .k {
      font-size: 9.3px;
      color: var(--muted);
      font-weight: 700;
      margin-bottom: 0.6mm;
    }

    .mini .v {
      font-size: 14.5px;
      font-weight: 900;
      line-height: 1.06;
      letter-spacing: -0.03em;
      margin-bottom: 0.6mm;
    }

    .mini .n {
      font-size: 8.8px;
      line-height: 1.28;
      color: rgba(23, 23, 28, 0.54);
    }

    .subsection {
      margin-top: 2.4mm;
    }

    .subsection:first-child {
      margin-top: 0;
    }

    .sub-title {
      margin: 0 0 2mm 0;
      font-size: 11px;
      line-height: 1.2;
      font-weight: 800;
      color: var(--black);
    }

    .stats-list {
      display: grid;
      gap: 2mm;
    }

    .stats-row {
      display: grid;
      grid-template-columns: 1.2fr 1fr 1fr;
      gap: 2mm;
      align-items: center;
      border: 1px solid var(--line);
      background: #fcfbff;
      border-radius: 12px;
      padding: 2.4mm 2.6mm;
    }

    .stats-row .name {
      font-size: 9.5px;
      font-weight: 800;
      line-height: 1.2;
    }

    .stats-row .val {
      font-size: 9.4px;
      line-height: 1.25;
      color: var(--black);
    }

    .hist-wrap {
      display: grid;
      gap: 2mm;
    }

    .hist-card {
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      background: #fcfbff;
      padding: 2.5mm;
    }

    .hist-title {
      font-size: 9.8px;
      font-weight: 800;
      margin-bottom: 1.5mm;
    }

    .hist-svg {
      width: 100%;
      height: 42mm;
      display: block;
    }

    .notes {
      display: grid;
      gap: 2.2mm;
      margin-top: auto;
    }

    .note-box {
      display: grid;
      grid-template-columns: 5mm 1fr;
      gap: 2.2mm;
      align-items: start;
      border-radius: var(--radius-md);
      border: 1px solid var(--line);
      background: var(--white);
      padding: 2.8mm 3mm;
    }

    .dot {
      width: 5mm;
      height: 5mm;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--red), var(--purple));
      margin-top: 1px;
    }

    .note-text {
      font-size: 9.2px;
      line-height: 1.34;
      color: var(--black);
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="top-line"></div>

    <div class="layout">
      <section class="header">
        <div>
          <div class="eyebrow">POST-ML • validation dashboard</div>
          <h1>{{ project_title }}</h1>
          <p class="subtitle">{{ summary_text }}</p>
        </div>
        <div class="logo-wrap">
          <div class="logo-box">
            <img src="{{ logo_path }}" alt="logo">
          </div>
        </div>
      </section>

      <section class="overview">
        {% for item in overview_cards %}
        <article class="card overview-card {{ item.tone }}">
          <div class="label">{{ item.label }}</div>
          <div class="value">{{ item.value }}</div>
          <div class="note">{{ item.note }}</div>
        </article>
        {% endfor %}

        <article class="hero">
          <div>
            <div class="k">Общая картина</div>
            <div class="v">{{ hero_total }}</div>
            <div class="t">
              Итоговый набор после сопоставления, обучения и заполнения высот. Проверяем, что данные не только полны, но и логически согласованы.
            </div>
          </div>
        </article>
      </section>

      <section class="middle">
        <article class="card panel">
          <div class="panel-head">
            <h2 class="panel-title">Геометрия и полнота</h2>
            <span class="pill">{{ total_cols }} колонок · {{ memory_mb }} MB</span>
          </div>

          <div class="score">
            <div class="score-top">
              <div class="left">
                <div class="k">Интегральная оценка валидации</div>
                <div class="v">{{ score }}</div>
              </div>
              <div class="right">{{ risk_label }}</div>
            </div>
            <div class="track"><div class="fill" style="width: {{ score }}%"></div></div>
          </div>

          <div class="subsection">
            <h3 class="sub-title">Геометрическая корректность</h3>
            <div class="mini-grid">
              {% for item in geometry_boxes %}
              <div class="mini">
                <div class="k">{{ item.k }}</div>
                <div class="v">{{ item.v }}</div>
                <div class="n">{{ item.n }}</div>
              </div>
              {% endfor %}
            </div>
          </div>

          <div class="subsection">
            <h3 class="sub-title">Полнота ключевых полей</h3>
            <div class="mini-grid">
              {% for item in completeness_boxes %}
              <div class="mini">
                <div class="k">{{ item.k }}</div>
                <div class="v">{{ item.v }}</div>
                <div class="n">{{ item.n }}</div>
              </div>
              {% endfor %}
            </div>
          </div>
        </article>

        <article class="card panel">
          <div class="panel-head">
            <h2 class="panel-title">Диапазоны и ML-логика</h2>
            <span class="pill">Observed vs CatBoost</span>
          </div>

          <div class="subsection">
            <h3 class="sub-title">Физическая достоверность значений</h3>
            <div class="mini-grid">
              {% for item in ranges_boxes %}
              <div class="mini">
                <div class="k">{{ item.k }}</div>
                <div class="v">{{ item.v }}</div>
                <div class="n">{{ item.n }}</div>
              </div>
              {% endfor %}
            </div>
          </div>

          <div class="subsection">
            <h3 class="sub-title">Целостность заполнения высот</h3>
            <div class="mini-grid">
              {% for item in ml_boxes %}
              <div class="mini">
                <div class="k">{{ item.k }}</div>
                <div class="v">{{ item.v }}</div>
                <div class="n">{{ item.n }}</div>
              </div>
              {% endfor %}
            </div>
          </div>


        </article>

        <aside class="card panel">
          <div class="panel-head">
            <h2 class="panel-title">Observed / predicted</h2>
            <span class="pill">Краткая статистика</span>
          </div>

          <div class="stats-list">
            {% for row in observed_vs_pred %}
            <div class="stats-row">
              <div class="name">{{ row.label }}</div>
              <div class="val">{{ row.a }}</div>
              <div class="val">{{ row.b }}</div>
            </div>
            {% endfor %}
          </div>


        </aside>
      </section>


    </div>
  </div>
</body>
</html>